                    "legend_enabled": true,
                    "nrql_query": [
                      {
                        "account_id": 2469734,
                        "query": "SELECT latest(`provider.databaseConnections.Maximum`) AS `CurrentConnections`\r\nFROM AwsDocDbClusterSample \r\nWHERE provider='AwsDocDbCluster' \r\nFACET CASES(\r\n  WHERE entityName = 'mdt-sdp-dlke-e1-u1-dhs-sds-edms-ddb' AS 'EDMS-UAT1-Pri-DocDB',\r\n  WHERE entityName = 'mdt-sdp-dlke-e1-d1-dhs-sds-edms-ddb' AS 'EDMS-Dev1-Pri-DocDB',\r\n  WHERE entityName = 'mdt-sdp-dlke-e1-d2-dhs-sds-edms-ddb' AS 'EDMS-Dev2-Pri-DocDB',\r\n  WHERE entityName = 'ddb-ssdpe1-mdt-ecms-d3-cluster' AS 'EDMS-Dev3-Pri-DocDB',\r\n  WHERE entityName = 'ddb-ssdpe1-mdt-ecms-u2-cluster' AS 'EDMS-UAT2-Pri-DocDB',\r\n  WHERE entityName = 'ddb-ssdpe1-mdt-ecms-d1-sec-cluster' AS 'EDMS-Dev1-Sec-DocDB',\r\n  WHERE entityName = 'ddb-ssdpe1-mdt-ecms-d3-sec-cluster' AS 'EDMS-Dev3-Sec-DocDB',\r\n  WHERE entityName = 'ddb-ssdpe1-mdt-cjams-forms-d1-cluster' AS 'CJAMS-Dev1-Pri-DocDB',\r\n  WHERE entityName = 'ddb-ssdpe1-mdt-ecms-d2-sec-cluster' AS 'EDMS-Dev2-Sec-DocDB',\r\n  WHERE entityName = 'ddb-ssdpe1-mdt-ecms-u1-sec-cluster' AS 'EDMS-UAT1-Sec-DocDB',\r\n  WHERE entityName = 'ddb-ssdpe1-mdt-r360-u1-cluster' AS 'R360-UAT1-Pri-DocDB',\r\n  WHERE entityName = 'ddb-ssdpe1-mdt-r360-d1-cluster' AS 'R360-Dev1-Pri-DocDB',\r\n  WHERE entityName = 'ddb-ssdpe1-mdt-data-portal-d1-cluster' AS 'DataPortal-Dev1-Pri-DocDB'\r\n) \r\n"
                      }
                    ],
                    "null_values": [],
                    "refresh_rate": "",
                    "row": 1,
                    "title": "Cluster Connection Counts (DEV)",
                    "units": [],
                    "warning": "",
                    "width": 6,
                    "y_axis_left_max": 0,
                    "y_axis_left_min": 0
                  }
                ],
                "widget_bullet": [],
                "widget_funnel": [],
                "widget_heatmap": [],
                "widget_histogram": [],
                "widget_json": [],
                "widget_line": [
                  {
