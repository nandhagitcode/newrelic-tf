    {
      "mode": "managed",
      "type": "newrelic_nrql_alert_condition",
      "name": "ec2_cpu_dev_utilz_condition",
      "provider": "provider[\"registry.terraform.io/newrelic/newrelic\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "account_id": 2469734,
            "aggregation_delay": "120",
            "aggregation_method": "event_flow",
            "aggregation_timer": null,
            "aggregation_window": 60,
            "baseline_direction": null,
            "close_violations_on_expiration": false,
            "critical": [
              {
                "duration": 0,
                "operator": "above",
                "threshold": 80,
                "threshold_duration": 300,
                "threshold_occurrences": "all",
                "time_function": ""
              }
            ],
            "description": "",
            "enabled": true,
            "entity_guid": "MjQ2OTczNHxBSU9QU3xDT05ESVRJT058NDU1Mzg1OTU",
            "evaluation_delay": null,
            "expiration_duration": 0,
            "fill_option": "none",
            "fill_value": 0,
            "id": "5723911:45538595",
            "ignore_on_expected_termination": false,
            "name": "EC2-CPU-Metrix (DEV)",
            "nrql": [
              {
                "data_account_id": 0,
                "evaluation_offset": 0,
                "query": "SELECT \r\n  average(cpuPercent) \r\nFROM \r\n  SystemSample \r\nWHERE \r\n  provider = 'Ec2Instance' \r\nFACET \r\n  CASES(\r\n    // MDM Dev Servers (6)\r\n    WHERE entityName = 'ssdpemdmd1e1a01.mdcloud.local' AS 'MDM-APP-Dev',\r\n    WHERE entityName = 'ssdpemdmd2e1a01.mdcloud.local' AS 'MDM-APP-Dev-EnHans',\r\n    WHERE entityName = 'ssdpemdmu1e1a04.mdcloud.local' AS 'MDM-APP-UAT-Node-1',\r\n    WHERE entityName = 'ssdpemdmu1e1c03.mdcloud.local' AS 'MDM-APP-UAT-Node-2',\r\n    WHERE entityName = 'ssdpemdmu2e1a01.mdcloud.local' AS 'MDM-APP-UAT-EnHans',\r\n    // SQL Dev Server (4)\r\n    WHERE entityName = 'SSDPMSQLD1E1A03' AS 'SDP-SQL-Dev',\r\n    WHERE entityName = 'SSDPMSQLD1E1A04' AS 'SDP-SQL-Dev-EnHans',\r\n    WHERE entityName = 'SSDPMSQLUTE1C01' AS 'SDP-SQL-UAT-Pri',\r\n    WHERE entityName = 'SSDPMSQLUTE1A01' AS 'SDP-SQL-UAT-Sec'\r\n  )\r\n",
                "since_value": ""
              }
            ],
            "open_violation_on_expiration": false,
            "policy_id": 5723911,
            "runbook_url": "",
            "slide_by": null,
            "term": [],
            "timeouts": null,
            "title_template": "",
            "type": "static",
            "violation_time_limit": "NON_MATCHABLE_LIMIT_VALUE",
            "violation_time_limit_seconds": 259200,
            "warning": [
              {
                "duration": 0,
                "operator": "above",
                "threshold": 70,
                "threshold_duration": 300,
                "threshold_occurrences": "all",
                "time_function": ""
              }
            ]
          },
          "sensitive_attributes": [],
          "private": "eyJlMmJmYjczMC1lY2FhLTExZTYtOGY4OC0zNDM2M2JjN2M0YzAiOnsiY3JlYXRlIjozMDAwMDAwMDAwMH19",
          "dependencies": [
            "newrelic_alert_policy.ec2_alert_policy"
          ]
        }
      ]
    },
